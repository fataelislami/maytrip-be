###############################################################################
# Maytrip backend — production environment template.
#
# Copy to `.env.production` on the VPS and fill in the real values.
# NEVER commit the real .env.production. Only this *.example file.
###############################################################################

# --- App ---
APP_NAME=Maytrip
APP_ENV=production
# Generate once on the VPS:   docker compose run --rm php php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://api.maytrip.co
APP_DOMAIN=api.maytrip.co
FRONTEND_URL=https://maytrip.co

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# --- Logging ---
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# --- Database (docker network) ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=maytrip
DB_USERNAME=maytrip
# Set both to long random strings. Different from each other.
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_ROOT_PASSWORD=CHANGE_ME_different_strong_root_password_here

# --- Sessions / Cache (file is fine until traffic justifies redis) ---
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
CACHE_STORE=file
QUEUE_CONNECTION=sync

# --- Sanctum ---
# Frontend domain that may send authenticated cookies. Comma-separated.
SANCTUM_STATEFUL_DOMAINS=maytrip.co
SESSION_DOMAIN=.maytrip.co

# --- CORS ---
# Whitelist the frontend origin only. Update if you add another surface.
CORS_ALLOWED_ORIGINS=https://maytrip.co

# --- Google OAuth (rotate from dev — generate NEW credentials for prod) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.maytrip.co/api/auth/google/callback

# --- Filesystem (local volume for now; move to s3/r2 later) ---
FILESYSTEM_DISK=public

# --- Mail (Postmark/Resend later; log to file for now) ---
MAIL_MAILER=log

# --- Misc ---
APP_MAINTENANCE_DRIVER=file
BROADCAST_CONNECTION=log

# --- Trusted proxies (Caddy is in front of php-fpm, share docker network) ---
TRUSTED_PROXIES=*

# --- Container user mapping ---
# Match your VPS user's UID/GID so bind-mounted storage is writable without root.
WWWUSER=1000
WWWGROUP=1000

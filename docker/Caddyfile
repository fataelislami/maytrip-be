# Production Caddyfile — handles HTTPS termination, gzip, static assets,
# and proxies PHP requests to php-fpm.
#
# Override the host with APP_DOMAIN in .env.production (default api.maytrip.co).

{$APP_DOMAIN:api.maytrip.co} {
    root * /var/www/html/public

    encode gzip zstd

    # Long cache for fingerprinted assets and uploads
    @assets {
        path /storage/* /build/* *.css *.js *.png *.jpg *.jpeg *.webp *.svg *.ico *.woff2
    }
    header @assets Cache-Control "public, max-age=2592000, immutable"

    # Security headers (HSTS only kicks in once cert is live)
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-Frame-Options "DENY"
        -Server
    }

    php_fastcgi php:9000

    file_server

    log {
        output stdout
        format console
    }
}
